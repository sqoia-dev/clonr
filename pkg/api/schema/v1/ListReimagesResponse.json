        "dry_run": {
          "type": "boolean"
        },
        "bios_only": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "exit_code": {
          "type": "integer"
        },
        "exit_name": {
          "type": "string"
        },
        "phase": {
