        "total": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ReimageRequest": {
      "properties": {
        "id": {
          "type": "string"
        },
        "node_id": {
          "type": "string"
        },
        "image_id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "scheduled_at": {
          "type": "string",
          "format": "date-time"
        },
        "triggered_at": {
          "type": "string",
          "format": "date-time"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "error_message": {
