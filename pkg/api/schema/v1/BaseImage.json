{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sqoia-dev/clustr/pkg/api/base-image",
  "$ref": "#/$defs/BaseImage",
  "$defs": {
    "BaseImage": {
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "os": {
          "type": "string"
        },
        "arch": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "firmware": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer"
        },
        "checksum": {
          "type": "string"
        },
        "disk_layout": {
          "$ref": "#/$defs/DiskLayout"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "source_url": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "error_message": {
          "type": "string"
        },
        "build_method": {
          "type": "string"
        },
        "built_for_roles": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "install_instructions": {
          "items": {
            "$ref": "#/$defs/InstallInstruction"
          },
          "type": "array"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "finalized_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "os",
        "arch",
        "status",
        "format",
        "firmware",
        "size_bytes",
        "checksum",
        "disk_layout",
        "tags",
        "notes",
        "created_at"
      ]
    },
    "Bootloader": {
      "properties": {
        "type": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "target"
      ]
    },
    "DiskLayout": {
      "properties": {
        "raid_arrays": {
          "items": {
            "$ref": "#/$defs/RAIDSpec"
          },
          "type": "array"
        },
        "zfs_pools": {
          "items": {
            "$ref": "#/$defs/ZFSPool"
          },
          "type": "array"
        },
        "partitions": {
          "items": {
            "$ref": "#/$defs/PartitionSpec"
          },
          "type": "array"
        },
        "bootloader": {
          "$ref": "#/$defs/Bootloader"
        },
        "target_device": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "partitions",
        "bootloader"
      ]
    },
    "InstallInstruction": {
      "properties": {
        "opcode": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "payload": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "opcode",
        "target",
        "payload"
      ]
    },
    "PartitionSpec": {
      "properties": {
        "device": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer"
        },
        "filesystem": {
          "type": "string"
        },
        "mountpoint": {
          "type": "string"
        },
        "flags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "min_bytes": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "label",
        "size_bytes",
        "filesystem",
        "mountpoint",
        "flags",
        "min_bytes"
      ]
    },
    "RAIDSpec": {
      "properties": {
        "name": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "members": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "chunk_kb": {
          "type": "integer"
        },
        "spare": {
          "type": "integer"
        },
        "force_software": {
          "type": "boolean"
        },
        "raid_type": {
          "type": "string"
        },
        "imsm_container": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "level",
        "members"
      ]
    },
    "ZFSPool": {
      "properties": {
        "name": {
          "type": "string"
        },
        "vdev_type": {
          "type": "string"
        },
        "members": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "mountpoint": {
          "type": "string"
        },
        "properties": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "vdev_type",
        "members",
        "mountpoint"
      ]
    }
  }
}
