{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sqoia-dev/clustr/pkg/api/list-boot-entries-response",
  "$ref": "#/$defs/ListBootEntriesResponse",
  "$defs": {
    "BootEntry": {
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "kernel_url": {
          "type": "string"
        },
        "initrd_url": {
          "type": "string"
        },
        "cmdline": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ListBootEntriesResponse": {
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/BootEntry"
          },
          "type": "array"
        },
        "total": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}
