{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sqoia-dev/clustr/pkg/api/log-entry",
  "$ref": "#/$defs/LogEntry",
  "$defs": {
    "LogEntry": {
      "properties": {
        "id": {
          "type": "string"
        },
        "node_mac": {
          "type": "string"
        },
        "hostname": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "fields": {
          "type": "object"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}
