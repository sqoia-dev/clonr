{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sqoia-dev/clustr/pkg/api/create-node-config-request",
  "$ref": "#/$defs/CreateNodeConfigRequest",
  "$defs": {
    "CreateNodeConfigRequest": {
      "properties": {
        "hostname": {
          "type": "string"
        },
        "fqdn": {
          "type": "string"
        },
        "primary_mac": {
          "type": "string"
        },
        "interfaces": {
          "items": {
            "$ref": "#/$defs/InterfaceConfig"
          },
          "type": "array"
        },
        "ssh_keys": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kernel_args": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "groups": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "custom_vars": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "base_image_id": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "InterfaceConfig": {
      "properties": {
        "mac_address": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "ip_address": {
          "type": "string"
        },
        "gateway": {
          "type": "string"
        },
        "dns": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "mtu": {
          "type": "integer"
        },
        "bond": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}
