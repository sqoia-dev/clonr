{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sqoia-dev/clustr/pkg/api/list-disk-layouts-response",
  "$ref": "#/$defs/ListDiskLayoutsResponse",
  "$defs": {
    "Bootloader": {
      "properties": {
        "type": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "DiskLayout": {
      "properties": {
        "raid_arrays": {
          "items": {
            "$ref": "#/$defs/RAIDSpec"
          },
          "type": "array"
        },
        "zfs_pools": {
          "items": {
            "$ref": "#/$defs/ZFSPool"
          },
          "type": "array"
        },
        "partitions": {
          "items": {
            "$ref": "#/$defs/PartitionSpec"
          },
          "type": "array"
        },
        "bootloader": {
          "$ref": "#/$defs/Bootloader"
        },
        "target_device": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ListDiskLayoutsResponse": {
      "properties": {
        "layouts": {
          "items": {
            "$ref": "#/$defs/StoredDiskLayout"
          },
          "type": "array"
        },
        "total": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "PartitionSpec": {
      "properties": {
        "device": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer"
        },
        "filesystem": {
          "type": "string"
        },
        "mountpoint": {
          "type": "string"
        },
        "flags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "min_bytes": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "RAIDSpec": {
      "properties": {
        "name": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "members": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "chunk_kb": {
          "type": "integer"
        },
        "spare": {
          "type": "integer"
        },
        "force_software": {
          "type": "boolean"
        },
        "raid_type": {
          "type": "string"
        },
        "imsm_container": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "StoredDiskLayout": {
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "source_node_id": {
          "type": "string"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "layout": {
          "$ref": "#/$defs/DiskLayout"
        },
        "firmware_kind": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ZFSPool": {
      "properties": {
        "name": {
          "type": "string"
        },
        "vdev_type": {
          "type": "string"
        },
        "members": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "mountpoint": {
          "type": "string"
        },
        "properties": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}
