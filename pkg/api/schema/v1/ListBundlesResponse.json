{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sqoia-dev/clustr/pkg/api/list-bundles-response",
  "$ref": "#/$defs/ListBundlesResponse",
  "$defs": {
    "Bundle": {
      "properties": {
        "name": {
          "type": "string"
        },
        "slurm_version": {
          "type": "string"
        },
        "bundle_version": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "slurm_version",
        "bundle_version",
        "sha256",
        "kind",
        "source"
      ]
    },
    "ListBundlesResponse": {
      "properties": {
        "bundles": {
          "items": {
            "$ref": "#/$defs/Bundle"
          },
          "type": "array"
        },
        "total": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "bundles",
        "total"
      ]
    }
  }
}
