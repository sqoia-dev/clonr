{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sqoia-dev/clustr/pkg/api/raid-spec",
  "$ref": "#/$defs/RAIDSpec",
  "$defs": {
    "RAIDSpec": {
      "properties": {
        "name": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "members": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "chunk_kb": {
          "type": "integer"
        },
        "spare": {
          "type": "integer"
        },
        "force_software": {
          "type": "boolean"
        },
        "raid_type": {
          "type": "string"
        },
        "imsm_container": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "level",
        "members"
      ]
    }
  }
}
