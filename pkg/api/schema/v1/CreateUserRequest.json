{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sqoia-dev/clustr/pkg/api/create-user-request",
  "$ref": "#/$defs/CreateUserRequest",
  "$defs": {
    "CreateUserRequest": {
      "properties": {
        "username": {
          "type": "string",
          "minLength": 1
        },
        "password": {
          "type": "string",
          "minLength": 8
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "operator",
            "readonly",
            "viewer",
            "pi",
            "director"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "username",
        "password",
        "role"
      ]
    }
  }
}
