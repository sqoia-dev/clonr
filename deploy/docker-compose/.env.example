# clustr-serverd Docker Compose environment template
# Copy this file to /etc/clustr/clustr.env and edit the values below.
#
# Usage (from docs/install.md Quick Start step 2):
#   curl -fsSL https://raw.githubusercontent.com/sqoia-dev/clustr/main/deploy/docker-compose/.env.example \
#     -o /etc/clustr/clustr.env
#   # Edit /etc/clustr/clustr.env — at minimum, set CLUSTR_PXE_INTERFACE.
#   # Then: cd /etc/clustr && docker compose up -d
#
# Secrets (CLUSTR_SECRET_KEY, CLUSTR_SESSION_SECRET) must be in a SEPARATE
# file: /etc/clustr/secrets.env — see docs/install.md §3.2 for generation.
# Never put secrets in this file.
#
# Full env var reference: docs/install.md §5

# ──────────────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────────────

# HTTP listen address. Must be on the provisioning interface IP so PXE-booted
# nodes can reach the API. Change only if you understand the security implications.
CLUSTR_LISTEN_ADDR=10.99.0.1:8080

# ──────────────────────────────────────────────────────────────────────────────
# Data directories (bind-mounted from the host in docker-compose.yml)
# ──────────────────────────────────────────────────────────────────────────────

CLUSTR_IMAGE_DIR=/var/lib/clustr/images
CLUSTR_DB_PATH=/var/lib/clustr/db/clustr.db
CLUSTR_BOOT_DIR=/var/lib/clustr/boot
CLUSTR_TFTP_DIR=/var/lib/clustr/tftpboot
CLUSTR_LOG_ARCHIVE_DIR=/var/lib/clustr/log-archive

# ──────────────────────────────────────────────────────────────────────────────
# PXE server (DHCP + TFTP)
# ──────────────────────────────────────────────────────────────────────────────

CLUSTR_PXE_ENABLED=true

# REQUIRED: set to your provisioning interface name. Run "ip link" to list.
# Common names: eth1, ens3, enp3s0, eno2, bond1
# There is no safe default — you MUST change this to your actual NIC name.
# Wrong value = DHCP silently broken for all nodes.
CLUSTR_PXE_INTERFACE=eth1

# DHCP IP pool for PXE clients. Must be on the provisioning subnet.
CLUSTR_PXE_RANGE=10.99.0.100-10.99.0.200

# Server IP advertised to PXE clients (same host as CLUSTR_LISTEN_ADDR).
CLUSTR_PXE_SERVER_IP=10.99.0.1

# ──────────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────────

CLUSTR_LOG_LEVEL=info
CLUSTR_LOG_RETENTION=168h
CLUSTR_LOG_MAX_ROWS_PER_NODE=50000
