# clustr environment variable reference
#
# How to use:
#   This file documents every CLUSTR_* variable accepted by clustr-serverd.
#   Do NOT rename this file to `.env` and commit it — it contains placeholder
#   values.  Instead, create two files:
#
#     /etc/clustr/clustr.env   — non-secret config (copy from this template)
#     /etc/clustr/secrets.env  — secrets only (generate values, chmod 400)
#
# Generate secrets.env:
#   mkdir -p /etc/clustr && chmod 700 /etc/clustr
#   echo "CLUSTR_SECRET_KEY=$(openssl rand -hex 32)"     > /etc/clustr/secrets.env
#   echo "CLUSTR_SESSION_SECRET=$(openssl rand -hex 64)" >> /etc/clustr/secrets.env
#   chmod 400 /etc/clustr/secrets.env
#
# Full install guide: docs/install.md

# ─── Core paths ────────────────────────────────────────────────────────────────

# Listen address for the HTTP API and web UI.
# Use the provisioning interface IP to avoid exposing the API on the management LAN.
# With Docker Compose (network_mode: host) this is a real host IP.
CLUSTR_LISTEN_ADDR=10.99.0.1:8080

# Path to the SQLite database file.  Parent directory is created automatically.
CLUSTR_DB_PATH=/var/lib/clustr/db/clustr.db

# Directory for OS image blobs (rootfs tarballs).  100 GB+ recommended.
CLUSTR_IMAGE_DIR=/var/lib/clustr/images

# Directory for the PXE kernel and initramfs (served over HTTP to booting nodes).
CLUSTR_BOOT_DIR=/var/lib/clustr/boot

# TFTP root directory (iPXE binaries delivered via TFTP to PXE-booting nodes).
CLUSTR_TFTP_DIR=/var/lib/clustr/tftpboot

# Directory for purge-summary records written by the log purger.
CLUSTR_LOG_ARCHIVE_DIR=/var/lib/clustr/log-archive

# Temp workspace for ISO builds.  Should be on fast local storage.
# Overriding TMPDIR keeps QEMU temp files off the OS disk.
TMPDIR=/var/lib/clustr/tmp

# ─── Security (required in production) ────────────────────────────────────────

# AES-256-GCM key for encrypting BMC and LDAP credentials at rest.
# Required — server refuses to start if unset outside dev mode.
# Generate: openssl rand -hex 32
# Must go in secrets.env, NOT clustr.env.
# CLUSTR_SECRET_KEY=<set in secrets.env>

# HMAC key for browser session tokens.
# If unset, a random key is generated at startup — all sessions invalidated on restart.
# Generate: openssl rand -hex 64
# Must go in secrets.env, NOT clustr.env.
# CLUSTR_SESSION_SECRET=<set in secrets.env>

# Set to 1 to mark session cookies as Secure (requires TLS reverse proxy).
# Set to 1 in any deployment behind Caddy or another TLS terminator.
CLUSTR_SESSION_SECURE=0

# Dev-mode auth bypass.  NEVER use in production.
# Server refuses to start with this set unless listen address is loopback.
# CLUSTR_AUTH_DEV_MODE=0

# ─── PXE / DHCP / TFTP ────────────────────────────────────────────────────────

# Enable the built-in DHCP + TFTP + iPXE server.
# Required if nodes PXE boot via this host.
CLUSTR_PXE_ENABLED=true

# Host network interface on the provisioning segment.
# With Docker Compose (network_mode: host) this is a real host NIC name.
# Example: eth1, ens6, enp2s0
CLUSTR_PXE_INTERFACE=eth1

# DHCP pool for nodes without a static IP assigned in clustr.
# Format: <start>-<end>  (both inclusive)
CLUSTR_PXE_RANGE=10.99.0.100-10.99.0.200

# IP advertised as `next-server` in DHCP offers.
# Nodes download the initramfs from this address over HTTP.
# Must be reachable from the provisioning segment.
CLUSTR_PXE_SERVER_IP=10.99.0.1

# Prefix length of the provisioning subnet (DHCP Option 1).
# Default: 24  (/24 → 255.255.255.0)
CLUSTR_PXE_SUBNET_CIDR=24

# ─── Logging and retention ─────────────────────────────────────────────────────

# Log verbosity.  Values: debug, info, warn, error
CLUSTR_LOG_LEVEL=info

# TTL for node deploy log rows.  Go duration string: 168h = 7 days (default).
CLUSTR_LOG_RETENTION=168h

# Maximum deploy log rows retained per node.  Older rows evicted when exceeded.
CLUSTR_LOG_MAX_ROWS_PER_NODE=50000

# TTL for audit log rows (admin action log).  Default: 2160h = 90 days.
# CLUSTR_AUDIT_RETENTION=2160h

# ─── Image builds ──────────────────────────────────────────────────────────────

# Maximum number of ISO build VMs running simultaneously.
# Each QEMU VM uses ~2 GB RAM.  Default is based on available cores.
# CLUSTR_MAX_CONCURRENT_BUILDS=2

# Allow image pulls from RFC-1918 / loopback addresses.
# Safe to enable in air-gapped environments with an internal image registry.
# CLUSTR_ALLOW_PRIVATE_URLS=false

# ISO download/import staging directory.
# CLUSTR_ISO_DIR=/var/lib/clustr/iso-cache

# ─── Deploy and verify ─────────────────────────────────────────────────────────

# How long after a successful deploy the node has to POST to /verify-boot.
# Minimum 2m, maximum 30m.  Default: 5m.
# CLUSTR_VERIFY_TIMEOUT=5m

# Maximum concurrent node reimages.
# CLUSTR_REIMAGE_MAX_CONCURRENT=10

# Maximum concurrent boot-order reset operations (Proxmox).
CLUSTR_FLIP_CONCURRENCY=5

# ─── LDAP module directories ───────────────────────────────────────────────────
# Only needed if the LDAP module is enabled (Settings > LDAP in the web UI).

# CLUSTR_LDAP_DATA_DIR=/var/lib/clustr/ldap
# CLUSTR_LDAP_CONFIG_DIR=/etc/clustr/ldap
# CLUSTR_LDAP_PKI_DIR=/etc/clustr/pki

# ─── Backup scripts ────────────────────────────────────────────────────────────
# Used by scripts/ops/clustr-backup.sh — not read by clustr-serverd directly.

# Destination for DB backups.
# CLUSTR_BACKUP_DIR=/var/lib/clustr/backups

# Off-site rsync destination.  When unset, backups stay on the same volume (risky).
# Format: user@host:/path
# CLUSTR_BACKUP_REMOTE=

# Port for the ephemeral restore-verify instance started by clustr-backup-verify.sh.
# Must not conflict with CLUSTR_LISTEN_ADDR.
# CLUSTR_BACKUP_VERIFY_PORT=18080

# Seconds to wait for the verification instance to become ready.
# CLUSTR_BACKUP_VERIFY_WAIT=30
