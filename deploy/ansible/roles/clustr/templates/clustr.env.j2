# clustr runtime configuration — generated by Ansible
# Managed by Ansible role clustr — do not edit manually.
# Re-run the playbook to update this file.
#
# Secrets (CLUSTR_SECRET_KEY, CLUSTR_SESSION_SECRET) are in
# {{ clustr_config_dir }}/secrets.env (mode 0400).

# ─── Core paths ────────────────────────────────────────────────────────────────
CLUSTR_LISTEN_ADDR={{ clustr_listen_addr }}
CLUSTR_DB_PATH={{ clustr_db_path }}
CLUSTR_IMAGE_DIR={{ clustr_image_dir }}
CLUSTR_BOOT_DIR={{ clustr_boot_dir }}
CLUSTR_TFTP_DIR={{ clustr_tftp_dir }}
CLUSTR_LOG_ARCHIVE_DIR={{ clustr_log_archive_dir }}
TMPDIR={{ clustr_tmp_dir }}

# ─── PXE / DHCP / TFTP ────────────────────────────────────────────────────────
CLUSTR_PXE_ENABLED={{ clustr_pxe_enabled | lower }}
CLUSTR_PXE_INTERFACE={{ clustr_pxe_interface }}
CLUSTR_PXE_RANGE={{ clustr_pxe_range }}
CLUSTR_PXE_SERVER_IP={{ clustr_pxe_server_ip }}
CLUSTR_PXE_SUBNET_CIDR={{ clustr_pxe_subnet_cidr }}

# ─── Security ─────────────────────────────────────────────────────────────────
CLUSTR_SESSION_SECURE={{ clustr_session_secure }}

# ─── Logging ──────────────────────────────────────────────────────────────────
CLUSTR_LOG_LEVEL={{ clustr_log_level }}
CLUSTR_LOG_RETENTION={{ clustr_log_retention }}
CLUSTR_LOG_MAX_ROWS_PER_NODE={{ clustr_log_max_rows_per_node }}

# ─── Deploy tuning ────────────────────────────────────────────────────────────
CLUSTR_VERIFY_TIMEOUT={{ clustr_verify_timeout }}
CLUSTR_FLIP_CONCURRENCY={{ clustr_flip_concurrency }}
CLUSTR_ALLOW_PRIVATE_URLS={{ clustr_allow_private_urls | lower }}

# ─── Backup scripts ────────────────────────────────────────────────────────────
CLUSTR_BACKUP_DIR={{ clustr_backup_dir }}
{% if clustr_backup_remote | length > 0 %}
CLUSTR_BACKUP_REMOTE={{ clustr_backup_remote }}
{% endif %}
CLUSTR_BACKUP_VERIFY_PORT={{ clustr_backup_verify_port }}
