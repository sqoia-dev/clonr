# Juniper Junos set-commands generated by clustr
# Switch: {{ .SwitchName }}   Role: {{ .Role }}
# WARNING: Review before applying. Test in a maintenance window.

# ── VLAN definitions ──────────────────────────────────────────────────────────
{{ range .VLANs -}}
set vlans {{ .Name }} vlan-id {{ .ID }}
set vlans {{ .Name }} description "{{ .Description }}"
{{ end }}

# ── LLDP ─────────────────────────────────────────────────────────────────────
set protocols lldp interface all

# ── Server-facing ports ───────────────────────────────────────────────────────
{{ range .ServerPorts -}}
set interfaces {{ .Name }} description "{{ .Description }}"
set interfaces {{ .Name }} mtu {{ $.MTU }}
set interfaces {{ .Name }} unit 0 family ethernet-switching interface-mode {{ .Mode }}
{{ if eq .Mode "access" -}}
set interfaces {{ .Name }} unit 0 family ethernet-switching vlan members {{ .VLANID }}
{{ else -}}
set interfaces {{ .Name }} unit 0 family ethernet-switching vlan members {{ .VLANID }}
{{ end -}}
set protocols rstp interface {{ .Name }} edge
set protocols rstp interface {{ .Name }} no-root-port
{{ end }}

# ── Uplink ports ─────────────────────────────────────────────────────────────
{{ range .UplinkPorts -}}
set interfaces {{ .Name }} description "{{ .Description }}"
set interfaces {{ .Name }} mtu {{ $.MTU }}
set interfaces {{ .Name }} unit 0 family ethernet-switching interface-mode trunk
set interfaces {{ .Name }} unit 0 family ethernet-switching vlan members all
{{ end }}

# ── Aggregated Ethernet (LAGs) ─────────────────────────────────────────────
{{ range .LAGs -}}
set interfaces ae{{ .ID }} description "{{ .Description }}"
set interfaces ae{{ .ID }} mtu {{ $.MTU }}
{{ if eq .Mode "lacp" -}}
set interfaces ae{{ .ID }} aggregated-ether-options lacp active
{{ end -}}
{{ range .MemberPorts -}}
set interfaces {{ . }} ether-options 802.3ad ae{{ $.ID }}
{{ end -}}
{{ end }}

{{ if .EnablePFC -}}
# ── PFC / DCBX for RoCEv2 ────────────────────────────────────────────────────
set class-of-service interfaces {{ range .ServerPorts }}{{ .Name }} {{ end }}scheduler-map CLONR-PFC
{{ end }}
# End of generated configuration
