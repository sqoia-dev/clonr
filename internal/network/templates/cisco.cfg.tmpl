! Cisco NX-OS configuration generated by clustr
! Switch: {{ .SwitchName }}   Role: {{ .Role }}
! WARNING: Review before applying. Test in a maintenance window.

! ── VLAN definitions ──────────────────────────────────────────────────────────
{{ range .VLANs -}}
vlan {{ .ID }}
  name {{ .Name }}
{{ end }}

! ── LLDP ─────────────────────────────────────────────────────────────────────
feature lldp

! ── Server-facing ports ───────────────────────────────────────────────────────
{{ range .ServerPorts -}}
interface {{ .Name }}
  description {{ .Description }}
  {{ if eq .Mode "access" -}}
  switchport mode access
  switchport access vlan {{ .VLANID }}
  {{ else -}}
  switchport mode trunk
  switchport trunk allowed vlan {{ .VLANID }}
  {{ end -}}
  mtu {{ $.MTU }}
  spanning-tree port type edge
  spanning-tree bpduguard enable
  no shutdown
{{ end }}

! ── Uplink ports ─────────────────────────────────────────────────────────────
{{ range .UplinkPorts -}}
interface {{ .Name }}
  description {{ .Description }}
  switchport mode trunk
  switchport trunk allowed vlan all
  mtu {{ $.MTU }}
  no shutdown
{{ end }}

! ── Port-Channels ─────────────────────────────────────────────────────────────
{{ range .LAGs -}}
interface port-channel{{ .ID }}
  description {{ .Description }}
  mtu {{ $.MTU }}
  no shutdown

{{ range .MemberPorts -}}
interface {{ . }}
  channel-group {{ $.ID }} mode {{ if eq $.Mode "lacp" }}active{{ else }}on{{ end }}
{{ end -}}
{{ end }}

{{ if .EnablePFC -}}
! ── PFC / QoS for RoCEv2 (data role) ─────────────────────────────────────────
feature qos
system qos
  service-policy type qos input CLONR-RDMA
  service-policy type queuing input CLONR-RDMA-IN
  service-policy type queuing output CLONR-RDMA-OUT

class-map type qos match-all CLONR-RDMA-CLASS
  match cos {{ .PFCPriority }}

policy-map type qos CLONR-RDMA
  class CLONR-RDMA-CLASS
    pause pfc-cos {{ .PFCPriority }}
{{ end }}
! End of generated configuration
