# Dell OS10 configuration generated by clonr
# Switch: {{ .SwitchName }}   Role: {{ .Role }}
# WARNING: Review before applying. Test in a maintenance window.

# ── VLAN definitions ──────────────────────────────────────────────────────────
{{ range .VLANs -}}
interface vlan{{ .ID }}
 description {{ .Name }}
 no shutdown
{{ end }}

# ── LLDP ─────────────────────────────────────────────────────────────────────
lldp enable

# ── Server-facing ports ───────────────────────────────────────────────────────
{{ range .ServerPorts -}}
interface {{ .Name }}
 description {{ .Description }}
 {{ if eq .Mode "access" -}}
 switchport mode access
 switchport access vlan {{ .VLANID }}
 {{ else -}}
 switchport mode trunk
 switchport trunk allowed vlan {{ .VLANID }}
 {{ end -}}
 mtu {{ $.MTU }}
 spanning-tree portfast
 spanning-tree bpduguard enable
 no shutdown
{{ end }}

# ── Uplink ports ─────────────────────────────────────────────────────────────
{{ range .UplinkPorts -}}
interface {{ .Name }}
 description {{ .Description }}
 switchport mode trunk
 switchport trunk allowed vlan all
 mtu {{ $.MTU }}
 no shutdown
{{ end }}

# ── Port-Channels (LAGs) ─────────────────────────────────────────────────────
{{ range .LAGs -}}
interface port-channel{{ .ID }}
 description {{ .Description }}
 mtu {{ $.MTU }}
 no shutdown

{{ range .MemberPorts -}}
interface {{ . }}
 channel-group {{ $.ID }} mode {{ if eq $.Mode "lacp" }}active{{ else }}on{{ end }}
{{ end -}}
{{ end }}

{{ if .EnablePFC -}}
# ── DCB / PFC for RoCEv2 (data role) ─────────────────────────────────────────
dcb-map CLONR-RDMA
 priority-group 0 bandwidth 50 pfc on
 priority-pgid {{ .PFCPriority }} 0
{{ end }}
# End of generated configuration
