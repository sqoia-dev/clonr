! Arista EOS configuration generated by clonr
! Switch: {{ .SwitchName }}   Role: {{ .Role }}
! WARNING: Review before applying. Test in a maintenance window.

! ── VLAN definitions ──────────────────────────────────────────────────────────
{{ range .VLANs -}}
vlan {{ .ID }}
   name {{ .Name }}
{{ end }}
! ── Management plane ──────────────────────────────────────────────────────────
management ssh
   idle-timeout 30

! ── LLDP ─────────────────────────────────────────────────────────────────────
lldp run

! ── Server-facing ports ───────────────────────────────────────────────────────
{{ range .ServerPorts -}}
interface {{ .Name }}
   description {{ .Description }}
   {{ if eq .Mode "access" -}}
   switchport mode access
   switchport access vlan {{ .VLANID }}
   {{ else -}}
   switchport mode trunk
   switchport trunk allowed vlan {{ .VLANID }}
   {{ end -}}
   mtu {{ $.MTU }}
   spanning-tree portfast
   spanning-tree bpduguard enable
   no shutdown
{{ end }}
! ── Uplink ports ─────────────────────────────────────────────────────────────
{{ range .UplinkPorts -}}
interface {{ .Name }}
   description {{ .Description }}
   switchport mode trunk
   switchport trunk allowed vlan all
   mtu {{ $.MTU }}
   no shutdown
{{ end }}
! ── Port-Channels (LAGs) ─────────────────────────────────────────────────────
{{ range .LAGs -}}
{{- $lag := . -}}
interface Port-Channel{{ .ID }}
   description {{ .Description }}
   {{ if eq .Mode "lacp" -}}
   port-channel lacp fallback static
   {{ end -}}
   mtu {{ $.MTU }}
   no shutdown

{{ range .MemberPorts -}}
interface {{ . }}
   channel-group {{ $lag.ID }} mode {{ if eq $lag.Mode "lacp" }}active{{ else }}on{{ end }}
{{ end -}}
{{ end }}
{{ if .EnablePFC -}}
! ── PFC / QoS for RoCEv2 (data role) ─────────────────────────────────────────
dcbx mode ieee
priority-flow-control mode on
priority-flow-control priority {{ .PFCPriority }} no-drop
{{ end }}
! End of generated configuration
