# sssd.conf — generated by clonr-serverd for node {{.Hostname}}
# DO NOT EDIT — managed by clonr. Regenerated on each reimage.
#
# Authentication: LDAP with sssd, pam_mkhomedir for local home directories.
# TLS mode: LDAPS (ldaps://), certificate verification required (TLS_REQCERT demand).
# No NFS home directories in v1 (pam_mkhomedir creates local homes).

[sssd]
services = nss, pam
domains = {{.Domain}}

[nss]
homedir_substring = /home

[pam]
offline_credentials_expiration = 7

[domain/{{.Domain}}]
id_provider = ldap
auth_provider = ldap
chpass_provider = ldap
access_provider = ldap

ldap_uri = {{.ServerURI}}
ldap_search_base = {{.BaseDN}}

ldap_default_bind_dn = {{.ServiceBindDN}}
ldap_default_authtok_type = password
ldap_default_authtok = {{.ServiceBindPasswd}}

# User attributes (classic NIS / posixAccount schema)
ldap_user_object_class = posixAccount
ldap_user_search_base = ou=people,{{.BaseDN}}
ldap_user_name = uid
ldap_user_uid_number = uidNumber
ldap_user_gid_number = gidNumber
ldap_user_home_directory = homeDirectory
ldap_user_shell = loginShell
ldap_user_gecos = gecos
ldap_user_shadow_expire = shadowExpire

# Group attributes (classic NIS / posixGroup schema with memberUid)
ldap_group_object_class = posixGroup
ldap_group_search_base = ou=groups,{{.BaseDN}}
ldap_group_name = cn
ldap_group_gid_number = gidNumber
ldap_group_member = memberUid

# TLS — require valid certificate signed by our CA
ldap_tls_reqcert = demand
ldap_tls_cacert = /etc/pki/ca-trust/source/anchors/clonr-ca.crt

# Account policy: ppolicy overlay handles lockout server-side.
# Access order: ppolicy first (ppolicy lockout / forced-change check),
# then expire (shadowExpire=1 for manual clonr lock).
# ldap_pwd_policy=none disables sssd's local shadow aging check — all
# password policy enforcement happens server-side via the ppolicy overlay.
ldap_account_expire_policy = shadow
ldap_access_order = ppolicy, expire
ldap_use_ppolicy = true
ldap_pwd_policy = none

# Performance tuning
ldap_id_use_start_tls = false
ldap_referrals = false
enumerate = false
cache_credentials = true
entry_cache_timeout = 300
krb5_store_password_if_offline = false
