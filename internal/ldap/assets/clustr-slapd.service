[Unit]
Description=clustr slapd (OpenLDAP daemon — managed by clustr-serverd)
Documentation=https://github.com/sqoia-dev/clustr
After=network.target
# Ensure the distro slapd is masked (done by clustr-serverd during Enable()).
# This unit conflicts with the distro unit to prevent dual-running.
Conflicts=slapd.service

[Service]
Type=forking
User=ldap
Group=ldap
PIDFile=/run/slapd/slapd.pid
RuntimeDirectory=slapd
RuntimeDirectoryMode=0755

ExecStart=/usr/sbin/slapd \
    -F /etc/clustr/ldap/slapd.d \
    -h ldaps://0.0.0.0:636 \
    -u ldap \
    -g ldap

ExecReload=/bin/kill -HUP $MAINPID

# Restart automatically if slapd crashes. Do NOT restart if stopped by
# systemctl stop (clustr-serverd calls that explicitly on Disable()).
Restart=on-failure
RestartSec=5s
TimeoutStartSec=30s
TimeoutStopSec=30s

# Security hardening — slapd does not need most kernel capabilities.
CapabilityBoundingSet=CAP_NET_BIND_SERVICE CAP_SETUID CAP_SETGID
AmbientCapabilities=CAP_NET_BIND_SERVICE
PrivateTmp=true
NoNewPrivileges=false

[Install]
WantedBy=multi-user.target
